### Tao 1 docker file:
https://docs.docker.com/get-started/02_our_app/

 context :
 
FROM ubuntu:20.04

# setup and install package
CMD ["/bin/sleep", "3650d"] ---> cung co the su dung ENTRYPOINT thay cho CMD
RUN apt-get update && apt-get install -y inetutils-ping telnet wget vim curl

# setup Helm
RUN apt-get install -y gpg
RUN curl https://baltocdn.com/helm/signing.asc | gpg --dearmor | tee /usr/share/keyrings/helm.gpg > /dev/null
RUN apt-get install -y apt-transport-https
RUN echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/helm.gpg] https://baltocdn.com/helm/stable/debian/ all main" | tee /etc/apt/sources.list.d/helm-stable-debian.list
RUN apt-get update
RUN apt-get install -y helm
RUN helm version

# setup kubectl
RUN curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
RUN curl -LO "https://dl.k8s.io/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl.sha256"
RUN echo "$(cat kubectl.sha256)  kubectl" | sha256sum --check
RUN install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
RUN kubectl version --client

# setup kubectl
RUN mkdir -p ~/.kube
RUN touch ~/.kube/config

docker build -t ubuntu-cmd .
docker tag ff346bdf9a84 phamtu/ubuntu-tupt:v1.3
docker push phamtu/ubuntu-tupt:v1.3
